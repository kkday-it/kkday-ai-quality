# backend/.env 範本 —— 複製為 backend/.env 後填入實際值（.env 已 gitignore，勿 commit）。
# 啟動時由 app/api/main.py 的 load_dotenv() 載入。此處僅放「機密 / 環境相關」值；
# 非機密的共用預設（QC DB host/port、LLM provider 目錄等）在 repo 根 config/defaults.json。

# ── 認證 ──────────────────────────────────────────────
# JWT 簽章金鑰（未設則用開發 fallback 並告警；正式環境務必設定）
AIPQ_JWT_SECRET=

# ── LLM（fallback；優先級低於 DB user_settings 面板設定）──
# 使用者未在面板填 token 時的 OpenAI key fallback
OPENAI_API_KEY=
# 使用者未在面板選 model 時的 model fallback
AI_JUDGE_MODEL=gpt-5-mini

# ── KKday B2C API（datasource live 模式才需要；fixture 模式不觸發）──
KKDAY_B2C_TOKEN1=
KKDAY_X_AUTH_TOKEN=

# ── Mixpanel 進線 CLI（python -m app.judge.ingest.mixpanel_feedback 才需要）──
MIXPANEL_SA_USERNAME=
MIXPANEL_SA_PASSWORD=
MIXPANEL_PROJECT_ID=
MIXPANEL_TOKEN=
# 選用：輸出目錄
MIXPANEL_OUT_DIR=
