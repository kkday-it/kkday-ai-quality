# C-1 / C-2 Prompt Lab 環境設定範例。
# 複製為同目錄 `.env`（已 gitignore）後填入實際值；載入見 scripts/prompt_lab/common.py::load_env。
# 真實環境變數（export）與 CLI --model 皆優先於本檔。

# OpenAI 认证与端点（金钥请勿提交；本档仅范例）
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini 只用于 Generator，借此打破「同模型出题、同模型评判」闭环。
# 官方 Gemini 3.5 Flash model id：gemini-3.5-flash
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
PROMPT_LAB_GENERATOR_PROVIDER=gemini
# 留空即采用 Gemini 3.5 的官方默认 medium；可选 minimal|low|medium|high。
PROMPT_LAB_GEMINI_REASONING_EFFORT=medium

# 三個角色模型。PRD §8：Generator 與 Judge 建議不同 snapshot、Auditor 再另一個以維持隔離；
# 若僅一個模型可用，可全設相同——build_dataset 會在 manifest 標註隔離局限並建議提高人工抽檢比例。
PROMPT_LAB_GENERATOR_MODEL=gemini-3.5-flash
PROMPT_LAB_AUDITOR_MODEL=gpt-5.4-mini-2026-03-17
PROMPT_LAB_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
