# C-1 Prompt Lab 環境設定範例。
# 複製為同目錄 `.env`（已 gitignore）後填入實際值；載入見 scripts/prompt_lab/common.py::load_env。
# 真實環境變數（export）與 CLI --model 皆優先於本檔。

# OpenAI 認證與端點（金鑰請勿提交；本檔僅範例）
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_BASE_URL=https://api.openai.com/v1

# 三個角色模型。PRD §8：Generator 與 Judge 建議不同 snapshot、Auditor 再另一個以維持隔離；
# 若僅一個模型可用，可全設相同——build_dataset 會在 manifest 標註隔離局限並建議提高人工抽檢比例。
PROMPT_LAB_GENERATOR_MODEL=gpt-5.4-mini-2026-03-17
PROMPT_LAB_AUDITOR_MODEL=gpt-5.4-mini-2026-03-17
PROMPT_LAB_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
