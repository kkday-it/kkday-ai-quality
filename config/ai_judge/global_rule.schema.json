{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://kkday.com/ai-quality/schema/global_rule.schema.json",
 "title": "整體規則（global_rule.json）標準 v1.1",
 "description": "AI 法官整體規則（判決流程 SSOT）：極性閘門（attribute_when）/ 判官提示詞 / abstain 政策 / 證據政策（含 attr_min_confidence）/ cascade 兩階段（含低信心重路由）。域界線 SSOT＝各 rule_C-N 的 L1 canon，非本檔。配對資料檔：config/ai_judge/global_rule.json。",
 "type": "object",
 "additionalProperties": false,
 "required": [
  "polarity_gate",
  "abstain_policy",
  "evidence_policy",
  "cascade"
 ],
 "properties": {
  "$schema": {
   "type": "string"
  },
  "_meta": {
   "type": "object",
   "additionalProperties": true
  },
  "attribution_guidance": {
   "type": "string",
   "description": "歸因判官提示詞（角色 + 判斷流程；不含域界線/正反例，那些走 rule tree L1 canon）。空＝prejudge 回退 code default。"
  },
  "polarity_guidance": {
   "type": "string",
   "description": "極性判官提示詞（只判傾向、不歸因）。空＝prejudge 回退 code default。"
  },
  "polarity_gate": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "attribute_when"
   ],
   "properties": {
    "attribute_when": {
     "type": "array",
     "minItems": 1,
     "uniqueItems": true,
     "items": {
      "type": "string",
      "enum": [
       "negative",
       "neutral"
      ]
     },
     "description": "哪些整體傾向進歸因（positive 恆 non_issue，不可列入）。"
    },
    "note": {
     "type": "string"
    }
   }
  },
  "abstain_policy": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "l1",
    "l2",
    "l3"
   ],
   "properties": {
    "l1": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "l2": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "l3": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "note": {
     "type": "string"
    }
   }
  },
  "evidence_policy": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "require_quote_grounded",
    "l3_min_confidence"
   ],
   "properties": {
    "require_quote_grounded": {
     "type": "boolean"
    },
    "l3_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1
    },
    "attr_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1,
     "description": "attr 級最低信心：低於即整條歸因丟棄（殺 Stage 湊數殭屍列；0＝關閉）。"
    },
    "caps": {
     "type": "array",
     "items": {
      "type": "object",
      "additionalProperties": false,
      "required": [
       "domain",
       "require",
       "cap"
      ],
      "properties": {
       "domain": {
        "type": "string"
       },
       "require": {
        "type": "string"
       },
       "cap": {
        "type": "string"
       },
       "note": {
        "type": "string"
       }
      }
     }
    },
    "note": {
     "type": "string"
    }
   }
  },
  "cascade": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "enabled",
    "stageA_l1",
    "stageB"
   ],
   "properties": {
    "enabled": {
     "type": "boolean"
    },
    "reroute_on_low_conf": {
     "type": "boolean",
     "description": "低信心負反饋重路由：Stage B 棄權/低於 attr_min_confidence 的選項排除後重跑一次 Stage A 改判。"
    },
    "stage_a_level": {
     "type": "string",
     "enum": [
      "l1",
      "l1l2"
     ],
     "description": "Stage A 選擇顆粒度：l1＝六域（預設）；l1l2＝直選 L2 面向（32 項含 canon，Stage B 候選縮到該面向葉）。"
    },
    "stageA_l1": {
     "type": "object",
     "additionalProperties": false,
     "properties": {
      "model": {
       "type": "string"
      },
      "note": {
       "type": "string"
      }
     }
    },
    "stageB": {
     "type": "object",
     "additionalProperties": false,
     "properties": {
      "model": {
       "type": "string"
      },
      "note": {
       "type": "string"
      }
     }
    },
    "note": {
     "type": "string"
    }
   }
  },
  "prejudge_depth": {
   "type": "string",
   "enum": [
    "l2",
    "l3"
   ],
   "description": "初判歸因深度：l3＝完整 L1→L3 cascade；l2＝只判 L1+L2（單呼叫 32 面向目錄，L3 留待接上商品/訂單佐證的深判階段）。缺鍵＝l3。"
  }
 }
}