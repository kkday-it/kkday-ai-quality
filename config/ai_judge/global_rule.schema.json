{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://kkday.com/ai-quality/schema/global_rule.schema.json",
 "title": "整體規則（global_rule.json）標準 v2.0",
 "description": "AI 法官整體規則（判決流程 SSOT）：極性閘門（attribute_when）/ 證據政策（attr_min_confidence + secondary_min_confidence 閘門）。判官提示詞與域界線 SSOT＝docs/prompts/prompts/*.md（Prompt-as-Source），非本檔。配對資料檔：config/ai_judge/global_rule.json。",
 "type": "object",
 "additionalProperties": false,
 "required": [
  "polarity_gate",
  "evidence_policy"
 ],
 "properties": {
  "$schema": {
   "type": "string"
  },
  "_meta": {
   "type": "object",
   "additionalProperties": true
  },
  "polarity_gate": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "attribute_when"
   ],
   "properties": {
    "attribute_when": {
     "type": "array",
     "minItems": 1,
     "uniqueItems": true,
     "items": {
      "type": "string",
      "enum": [
       "negative",
       "neutral"
      ]
     },
     "description": "哪些整體傾向進歸因（positive 恆 non_issue，不可列入）。"
    },
    "note": {
     "type": "string"
    }
   }
  },
  "evidence_policy": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "require_quote_grounded"
   ],
   "properties": {
    "require_quote_grounded": {
     "type": "boolean"
    },
    "attr_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1,
     "description": "attr 級最低信心：低於即整條歸因丟棄（殺 Stage 湊數殭屍列；0＝關閉）。"
    },
    "note": {
     "type": "string"
    },
    "secondary_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1,
     "description": "多歸因時非 primary 條目最低信心：低於即丟棄只留主因（0＝關閉）。"
    }
   }
  }
 }
}
