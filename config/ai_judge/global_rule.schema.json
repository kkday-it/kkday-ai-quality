{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://kkday.com/ai-quality/schema/global_rule.schema.json",
 "title": "整體規則（global_rule.json）標準 v1.2",
 "description": "AI 法官整體規則（判決流程 SSOT）：極性閘門（attribute_when）/ 判官提示詞 / abstain 政策 / 證據政策（attr_min_confidence + secondary_min_confidence 閘門）/ l2 單呼叫深度 + 低信心重路由（cascade.reroute_on_low_conf）。域界線 SSOT＝各 rule_C-N 的 L1 canon，非本檔。配對資料檔：config/ai_judge/global_rule.json。",
 "type": "object",
 "additionalProperties": false,
 "required": [
  "polarity_gate",
  "abstain_policy",
  "evidence_policy",
  "cascade"
 ],
 "properties": {
  "$schema": {
   "type": "string"
  },
  "_meta": {
   "type": "object",
   "additionalProperties": true
  },
  "attribution_guidance": {
   "type": "string",
   "description": "歸因判官提示詞（角色 + 判斷流程；不含域界線/正反例，那些走 rule tree L1 canon）。空＝prejudge 回退 code default。"
  },
  "polarity_guidance": {
   "type": "string",
   "description": "極性判官提示詞（只判傾向、不歸因）。空＝prejudge 回退 code default。"
  },
  "polarity_gate": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "attribute_when"
   ],
   "properties": {
    "attribute_when": {
     "type": "array",
     "minItems": 1,
     "uniqueItems": true,
     "items": {
      "type": "string",
      "enum": [
       "negative",
       "neutral"
      ]
     },
     "description": "哪些整體傾向進歸因（positive 恆 non_issue，不可列入）。"
    },
    "note": {
     "type": "string"
    }
   }
  },
  "abstain_policy": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "l1",
    "l2",
    "l3"
   ],
   "properties": {
    "l1": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "l2": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "l3": {
     "type": "string",
     "enum": [
      "force_for_negative",
      "allow_empty_low_evidence"
     ]
    },
    "note": {
     "type": "string"
    }
   }
  },
  "evidence_policy": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "require_quote_grounded",
    "l3_min_confidence"
   ],
   "properties": {
    "require_quote_grounded": {
     "type": "boolean"
    },
    "l3_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1
    },
    "attr_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1,
     "description": "attr 級最低信心：低於即整條歸因丟棄（殺 Stage 湊數殭屍列；0＝關閉）。"
    },
    "note": {
     "type": "string"
    },
    "secondary_min_confidence": {
     "type": "number",
     "minimum": 0,
     "maximum": 1,
     "description": "多歸因時非 primary 條目最低信心：低於即丟棄只留主因（0＝關閉）。"
    }
   }
  },
  "cascade": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "reroute_on_low_conf"
   ],
   "properties": {
    "reroute_on_low_conf": {
     "type": "boolean",
     "description": "低信心負反饋重路由：Stage B 棄權/低於 attr_min_confidence 的選項排除後重跑一次 Stage A 改判。"
    },
    "note": {
     "type": "string"
    }
   }
  },
  "prejudge_depth": {
   "type": "string",
   "enum": [
    "l2",
    "l3"
   ],
   "description": "初判歸因深度：l3＝完整 L1→L3 cascade；l2＝只判 L1+L2（單呼叫 32 面向目錄，L3 留待接上商品/訂單佐證的深判階段）。缺鍵＝l3。"
  }
 }
}
