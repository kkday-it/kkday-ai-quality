{
  "$schema": "./source_mapping.schema.json",
  "_meta": {
    "version": "1.0",
    "about": "5 反饋來源 → 統一問題列表的欄位映射 SSOT。驅動：上傳表頭自動辨識(指紋)、必備欄校驗、原始列正規化(raw→canonical)。",
    "canonical_fields": [
      "source",
      "source_record_id",
      "occurred_at",
      "content",
      "title",
      "channel",
      "prod_oid",
      "pkg_oid",
      "order_oid",
      "supplier_oid",
      "member_uuid",
      "score",
      "lang"
    ],
    "notes": "source 由本檔的 key 自動填；field_map 未列的原始欄一律進 source_metadata(特殊欄)；const_fields 為無對應欄時的常數補值。required_headers 同時作為自動辨識指紋與必備欄校驗。"
  },
  "sources": {
    "conversations": {
      "label": "售前售後進線",
      "required_headers": ["session_oid", "aggregated_messages"],
      "field_map": {
        "session_oid": "source_record_id",
        "session_create_date": "occurred_at",
        "aggregated_messages": "content",
        "sessionable_type": "channel",
        "prod_oid": "prod_oid",
        "order_oid": "order_oid",
        "supplier_oid": "supplier_oid"
      },
      "const_fields": {}
    },
    "freshdesk_tickets": {
      "label": "工單",
      "required_headers": ["id", "description"],
      "field_map": {
        "id": "source_record_id",
        "created_at": "occurred_at",
        "subject": "title",
        "description": "content",
        "st_survey_rating": "score",
        "product_id": "prod_oid",
        "source_name": "channel"
      },
      "const_fields": {}
    },
    "product_reviews": {
      "label": "商品評論",
      "required_headers": ["rec_oid", "rec_desc"],
      "field_map": {
        "rec_oid": "source_record_id",
        "create_date": "occurred_at",
        "rec_title": "title",
        "rec_desc": "content",
        "rec_scores": "score",
        "lang_code": "lang",
        "prod_oid": "prod_oid",
        "pkg_oid": "pkg_oid",
        "order_oid": "order_oid",
        "order_mid": "order_mid",
        "supplier_oid": "supplier_oid",
        "member_uuid": "member_uuid",
        "traveller_type": "traveller_type",
        "lst_dt_go": "go_date",
        "product_category": "product_category"
      },
      "const_fields": {
        "channel": "review"
      }
    },
    "app_feedback": {
      "label": "App 回饋",
      "required_headers": ["oid", "comment"],
      "field_map": {
        "oid": "source_record_id",
        "created_datetime": "occurred_at",
        "comment": "content",
        "score": "score",
        "source": "channel",
        "lang_code": "lang"
      },
      "const_fields": {}
    },
    "mixpanel_tracker": {
      "label": "埋點",
      "required_headers": ["event", "feedback_signal"],
      "field_map": {
        "$insert_id": "source_record_id",
        "time": "occurred_at",
        "negative_items": "content",
        "event": "channel",
        "prod_mid": "prod_oid",
        "pkg_oid": "pkg_oid"
      },
      "const_fields": {}
    }
  }
}
