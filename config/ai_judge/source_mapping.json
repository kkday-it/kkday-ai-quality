{
 "_meta": {
  "about": "5 反饋來源 → 統一問題列表的欄位映射 SSOT。驅動：上傳表頭自動辨識(指紋)、必備欄校驗、原始列正規化(raw→canonical)。",
  "notes": "source 由本檔的 key 自動填；field_map 未列的原始欄一律進 source_metadata(特殊欄)；const_fields 為無對應欄時的常數補值；merge_fields（canonical 欄→[原始欄,...]）將多個原始欄依序串接（換行分隔）成單一 canonical 欄，用於單一原始欄無法承載全部內容的來源（如 conversations 的 chatbot_conversation+human_conversation→content）。required_headers 同時作為自動辨識指紋與必備欄校驗。顯示 label 不在本檔——SSOT 唯一在 config/global/sources.json（後端 source_mapping.source_label 委派 sources.label_for），避免兩處漂移。",
  "version": "1.0",
  "canonical_fields": [
   "source",
   "source_record_id",
   "occurred_at",
   "content",
   "title",
   "channel",
   "prod_oid",
   "pkg_oid",
   "order_oid",
   "supplier_oid",
   "supplier_name",
   "member_uuid",
   "score",
   "lang",
   "trip_stage",
   "msg_handler",
   "cs_task_type"
  ]
 },
 "$schema": "./source_mapping.schema.json",
 "sources": {
  "app_feedback": {
   "field_map": {
    "oid": "source_record_id",
    "score": "score",
    "source": "channel",
    "comment": "content",
    "lang_code": "lang",
    "created_datetime": "occurred_at"
   },
   "const_fields": {},
   "required_headers": [
    "oid",
    "comment"
   ]
  },
  "conversations": {
   "field_map": {
    "prod_oid": "prod_oid",
    "order_oid": "order_oid",
    "session_oid": "source_record_id",
    "supplier_oid": "supplier_oid",
    "supplier_name": "supplier_name",
    "conversation_type": "channel",
    "trip_stage": "trip_stage",
    "msg_handler": "msg_handler",
    "cs_task_type_name": "cs_task_type",
    "session_datetime_tw": "occurred_at"
   },
   "merge_fields": {
    "content": ["chatbot_conversation", "human_conversation"]
   },
   "const_fields": {},
   "required_headers": [
    "session_oid",
    "chatbot_conversation",
    "human_conversation"
   ]
  },
  "product_reviews": {
   "field_map": {
    "pkg_oid": "pkg_oid",
    "rec_oid": "source_record_id",
    "prod_oid": "prod_oid",
    "rec_desc": "content",
    "lang_code": "lang",
    "lst_dt_go": "go_date",
    "order_mid": "order_mid",
    "order_oid": "order_oid",
    "rec_title": "title",
    "rec_scores": "score",
    "create_date": "occurred_at",
    "member_uuid": "member_uuid",
    "supplier_oid": "supplier_oid",
    "traveller_type": "traveller_type",
    "product_category": "product_category"
   },
   "const_fields": {
    "channel": "review"
   },
   "required_headers": [
    "rec_oid",
    "rec_desc"
   ]
  },
  "mixpanel_tracker": {
   "field_map": {
    "time": "occurred_at",
    "event": "channel",
    "pkg_oid": "pkg_oid",
    "prod_mid": "prod_oid",
    "insert_id": "source_record_id",
    "negative_items": "content"
   },
   "const_fields": {},
   "required_headers": [
    "event",
    "feedback_signal"
   ]
  },
  "freshdesk_tickets": {
   "field_map": {
    "id": "source_record_id",
    "subject": "title",
    "created_at": "occurred_at",
    "product_id": "prod_oid",
    "description": "content",
    "source_name": "channel",
    "st_survey_rating": "score"
   },
   "const_fields": {},
   "required_headers": [
    "id",
    "description"
   ]
  }
 }
}
