{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kkday.com/ai-quality/schema/rule.schema.json",
  "$comment": "AI 法官問題分類規則樹標準 v1.0（JSON Schema draft 2020-12）。配對資料檔：data/rule.json。",
  "title": "問題分類規則樹（rule.json）標準 v1.0",
  "description": "AI 法官三層歸因分類樹的結構與規則唯一驗證標準。L1 歸因域 › L2 面向 › L3 細項；遞迴 children + 非補零 C-code（materialized path / SKOS notation）。每個 L3 葉節點扛完整判準（canon／正反例／鐵則）。欄位語義對齊 W3C SKOS（不引入 RDF）。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tree"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "指向本 schema 的路徑（編輯器自動驗證用），如 \"./schema.json\"。"
    },
    "_meta": {
      "$ref": "#/$defs/meta"
    },
    "tree": {
      "title": "歸因域森林",
      "description": "L1 歸因域節點清單（評論導向 6 域：① content ② product_quality ③ supplier ④ redemption ⑤ service ⑥ customer）。",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/l1"
      }
    }
  },
  "$defs": {
    "meta": {
      "title": "產生資訊（_meta）",
      "description": "標準版本與統計；純記錄，不參與判決。允許額外鍵（向前相容）。",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "string",
          "description": "本規則檔遵循的標準版本。",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "examples": [
            "1.0"
          ]
        },
        "about": {
          "type": "string",
          "description": "一句話說明本檔內容。"
        },
        "id_scheme": {
          "type": "string",
          "description": "C-code 編碼規則說明。"
        },
        "validate": {
          "type": "string",
          "description": "驗證指令備忘。"
        },
        "domain_count": {
          "type": "integer",
          "minimum": 1,
          "description": "L1 域數（應＝tree 長度）。"
        },
        "l3_total": {
          "type": "integer",
          "minimum": 1,
          "description": "L3 葉節點總數。"
        },
        "thick_fields_status": {
          "type": "string",
          "description": "厚判準欄位填充進度（M1/M3）。"
        }
      }
    },
    "label": {
      "title": "label 顯示名（SKOS prefLabel）",
      "description": "節點顯示名，純展示、不當引用（識別用 code）。限定詞用 - 連字號隔離，禁全形（）／半形()（見 scripts/normalize_labels.py）。",
      "type": "string",
      "minLength": 1,
      "pattern": "^[^（）()]+$",
      "examples": [
        "商品特色-Highlights"
      ]
    },
    "strList": {
      "title": "字串清單",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "leafFields": {
      "title": "葉節點判準欄位",
      "description": "任意層葉節點（無 children）須帶的完整判準；供 l1/l2/l3 共用語意。",
      "type": "object",
      "properties": {
        "meaning": { "type": "string", "description": "SKOS scopeNote：對旅客的價值／為何重要。" },
        "rule": { "type": "string", "description": "法典條文 ID（R*/E*/T*），可空。" },
        "canon": { "type": "string", "description": "SKOS definition：唯一判準。" },
        "allow": { "$ref": "#/$defs/strList", "description": "✅ 合規寫法。" },
        "forbid": { "$ref": "#/$defs/strList", "description": "❌ 違規寫法。" },
        "positive_cases": { "$ref": "#/$defs/strList", "description": "好範例（應判 Pass）。" },
        "negative_cases": { "$ref": "#/$defs/strList", "description": "壞範例（Red Flag）。" },
        "machine_clues": { "$ref": "#/$defs/strList", "description": "可程式檢查訊號。" }
      }
    },
    "l1": {
      "title": "L1 歸因域節點（分支或葉）",
      "description": "唯一帶 domain 英文機器值。有 children＝分支（children 為 L2）；無 children＝葉（直接帶判準，變深度：域即最終歸因層）。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "level",
        "domain",
        "label"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^C-[1-9][0-9]*$",
          "description": "L1 C-code（單段，非補零）。",
          "examples": [
            "C-1"
          ]
        },
        "level": {
          "const": 1,
          "description": "層級＝1（域）。"
        },
        "domain": {
          "type": "string",
          "enum": [
            "content",
            "product_quality",
            "supplier",
            "redemption",
            "service",
            "customer"
          ],
          "description": "歸因域英文機器值（後端判決鏈以此對齊 domains.json / pyramid）。評論導向 6 域：移除 platform/order/cs/force_majeure；新增 product_quality（產品實體品質）/redemption/service；現場人員（導遊/司機/接待）收斂於 supplier 供應商履約。"
        },
        "label": { "$ref": "#/$defs/label" },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/l2" },
          "description": "L2 面向節點清單（分支時）。"
        },
        "meaning": { "type": "string" },
        "rule": { "type": "string" },
        "canon": { "type": "string" },
        "allow": { "$ref": "#/$defs/strList" },
        "forbid": { "$ref": "#/$defs/strList" },
        "positive_cases": { "$ref": "#/$defs/strList" },
        "negative_cases": { "$ref": "#/$defs/strList" },
        "machine_clues": { "$ref": "#/$defs/strList" }
      },
      "allOf": [
        { "$comment": "分支：有 children 則不得帶判準", "if": { "required": ["children"] }, "then": { "not": { "required": ["canon"] } } },
        { "$comment": "葉：無 children 則須帶完整判準", "if": { "not": { "required": ["children"] } }, "then": { "required": ["meaning", "rule", "canon", "allow", "forbid", "positive_cases", "negative_cases", "machine_clues"] } }
      ]
    },
    "l2": {
      "title": "L2 面向節點（分支或葉）",
      "description": "有 children＝分支（children 為 L3）；無 children＝葉（直接帶判準，變深度：面向即最終歸因層，不強制細分 L3）。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "level",
        "label"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^C-[1-9][0-9]*-[1-9][0-9]*$",
          "description": "L2 C-code（兩段，非補零）。",
          "examples": [
            "C-1-1"
          ]
        },
        "level": {
          "const": 2,
          "description": "層級＝2（面向）。"
        },
        "label": { "$ref": "#/$defs/label" },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/l3" },
          "description": "L3 細項節點清單（分支時）。"
        },
        "meaning": { "type": "string" },
        "rule": { "type": "string" },
        "canon": { "type": "string" },
        "allow": { "$ref": "#/$defs/strList" },
        "forbid": { "$ref": "#/$defs/strList" },
        "positive_cases": { "$ref": "#/$defs/strList" },
        "negative_cases": { "$ref": "#/$defs/strList" },
        "machine_clues": { "$ref": "#/$defs/strList" }
      },
      "allOf": [
        { "$comment": "分支：有 children 則不得帶判準", "if": { "required": ["children"] }, "then": { "not": { "required": ["canon"] } } },
        { "$comment": "葉：無 children 則須帶完整判準", "if": { "not": { "required": ["children"] } }, "then": { "required": ["meaning", "rule", "canon", "allow", "forbid", "positive_cases", "negative_cases", "machine_clues"] } }
      ]
    },
    "l3": {
      "title": "L3 細項節點（葉）",
      "description": "leaf；扛完整判準。分類元數據（meaning/rule）+ 判準本體（canon/允許禁止/正反例/機器規則）。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "level",
        "label",
        "meaning",
        "rule",
        "canon",
        "allow",
        "forbid",
        "positive_cases",
        "negative_cases",
        "machine_clues"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^C-[1-9][0-9]*-[1-9][0-9]*-[1-9][0-9]*$",
          "description": "L3 C-code（三段，非補零）。",
          "examples": [
            "C-1-1-4"
          ]
        },
        "level": {
          "const": 3,
          "description": "層級＝3（細項，葉）。"
        },
        "label": {
          "$ref": "#/$defs/label"
        },
        "meaning": {
          "type": "string",
          "description": "SKOS scopeNote：這細項對旅客的價值／為何重要（動機，非判準；已剝離跨域根因標註）。",
          "examples": [
            "快速掃描差異價值"
          ]
        },
        "rule": {
          "type": "string",
          "description": "法典條文 ID（R*/E*/T*），溯源內容治理法典；可空。",
          "examples": [
            "R5"
          ]
        },
        "canon": {
          "type": "string",
          "description": "SKOS definition：唯一判準（§1 法典條文，arbiter L3 主依據）。空字串＝待 M1/M3 補。"
        },
        "allow": {
          "$ref": "#/$defs/strList",
          "description": "✅ 合規寫法（§2 正面邊界）。"
        },
        "forbid": {
          "$ref": "#/$defs/strList",
          "description": "❌ 違規寫法（§2 負面邊界）。"
        },
        "positive_cases": {
          "$ref": "#/$defs/strList",
          "description": "好範例（§3 應判 Pass，SKOS example）。"
        },
        "negative_cases": {
          "$ref": "#/$defs/strList",
          "description": "壞範例（§4 Red Flag，應判 Flag）。"
        },
        "machine_clues": {
          "$ref": "#/$defs/strList",
          "description": "可程式檢查訊號（§5，字典／格式比對）。"
        }
      }
    }
  }
}
